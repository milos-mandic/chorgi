#!/usr/bin/env python3
"""Cost dashboard — query spending from .personal/costs.log."""

import sys
from collections import defaultdict
from datetime import datetime, timedelta, timezone
from pathlib import Path

COSTS_LOG = Path(__file__).parent.parent / ".personal" / "costs.log"

# Anthropic published pricing (per million tokens)
HAIKU_INPUT_COST = 0.80   # per 1M input tokens
HAIKU_OUTPUT_COST = 4.00  # per 1M output tokens
# Claude Code sub-agent: no token info in log, estimate by wall-clock
SUBAGENT_COST_PER_MIN = 0.10  # rough estimate


def parse_log(cutoff: datetime | None = None) -> list[dict]:
    """Parse costs.log entries, optionally filtering by cutoff datetime."""
    if not COSTS_LOG.exists():
        return []

    entries = []
    for line in COSTS_LOG.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        parts = line.split(",")
        if len(parts) < 2:
            continue

        ts_str = parts[0]
        try:
            ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        except ValueError:
            continue

        if cutoff and ts < cutoff:
            continue

        event_type = parts[1]
        kv = {}
        for p in parts[2:]:
            if "=" in p:
                k, v = p.split("=", 1)
                kv[k] = v

        entries.append({"ts": ts, "type": event_type, **kv})
    return entries


def summarize(entries: list[dict], label: str):
    """Print a summary of cost entries."""
    if not entries:
        print(f"No data for {label}.")
        return

    # Event counts
    type_counts = defaultdict(int)
    for e in entries:
        type_counts[e["type"]] += 1

    # Haiku tokens
    haiku_input = 0
    haiku_output = 0
    for e in entries:
        if "input_tokens" in e:
            try:
                haiku_input += int(e["input_tokens"])
            except ValueError:
                pass
        if "output_tokens" in e:
            try:
                haiku_output += int(e["output_tokens"])
            except ValueError:
                pass

    # Sub-agent stats
    skill_counts = defaultdict(int)
    total_agent_secs = 0.0
    for e in entries:
        if e["type"] == "sub_agent":
            skill = e.get("skill", "unknown")
            skill_counts[skill] += 1
            try:
                total_agent_secs += float(e.get("elapsed_s", 0))
            except ValueError:
                pass

    # Estimated costs
    haiku_cost = (haiku_input / 1_000_000) * HAIKU_INPUT_COST + \
                 (haiku_output / 1_000_000) * HAIKU_OUTPUT_COST
    agent_cost = (total_agent_secs / 60) * SUBAGENT_COST_PER_MIN

    # Print
    print(f"=== {label} ===")
    print(f"Period: {entries[0]['ts'].strftime('%Y-%m-%d %H:%M')} — {entries[-1]['ts'].strftime('%Y-%m-%d %H:%M')} UTC")
    print(f"Total events: {len(entries)}")
    print()

    print("Event breakdown:")
    for t, c in sorted(type_counts.items(), key=lambda x: -x[1]):
        print(f"  {t}: {c}")
    print()

    if skill_counts:
        print("Sub-agent by skill:")
        for s, c in sorted(skill_counts.items(), key=lambda x: -x[1]):
            print(f"  {s}: {c}")
        print(f"  Total wall-clock: {total_agent_secs:.0f}s ({total_agent_secs/60:.1f}m)")
        print()

    print("Haiku tokens:")
    print(f"  Input:  {haiku_input:,}")
    print(f"  Output: {haiku_output:,}")
    print()

    print("Estimated cost:")
    print(f"  Haiku:      ${haiku_cost:.4f}")
    print(f"  Sub-agents: ${agent_cost:.4f} (est. ${SUBAGENT_COST_PER_MIN}/min)")
    print(f"  Total:      ${haiku_cost + agent_cost:.4f}")


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else "summary"
    now = datetime.now(timezone.utc)

    cutoffs = {
        "today": now.replace(hour=0, minute=0, second=0, microsecond=0),
        "week": now - timedelta(days=7),
        "summary": now - timedelta(days=7),
        "month": now - timedelta(days=30),
        "all": None,
    }

    if cmd not in cutoffs:
        print(f"Usage: costs [today|week|month|all|summary]")
        sys.exit(1)

    labels = {
        "today": "Today",
        "week": "Last 7 days",
        "summary": "Last 7 days (summary)",
        "month": "Last 30 days",
        "all": "All time",
    }

    entries = parse_log(cutoffs[cmd])
    summarize(entries, labels[cmd])


if __name__ == "__main__":
    main()
